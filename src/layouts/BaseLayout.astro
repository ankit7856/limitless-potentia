---
import "../styles/global.css";
import GlowBg from "../components/GlowBg.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import CalEmbed from "../components/CalEmbed.astro";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  navCtaTarget?: string;
  navCtaLabel?: string;
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage = "/og-image.png",
  navCtaTarget,
  navCtaLabel,
} = Astro.props;

const ogImageUrl = new URL(ogImage, Astro.site ?? Astro.url).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonical} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href="/logo-small.svg" />
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="antialiased selection:bg-mint selection:text-black">
    <GlowBg />
    <Nav ctaTarget={navCtaTarget} ctaLabel={navCtaLabel} />
    <slot />
    <Footer />
    <CalEmbed />
  </body>
</html>
