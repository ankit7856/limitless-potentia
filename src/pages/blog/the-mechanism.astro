<script is:inline>
  // Zone Carousel
  let currentZoneIndex = 0;
  const totalZones = 3;

  function updateZones(index, scrollToTarget = true) {
    currentZoneIndex = index;
    const cards = document.querySelectorAll(".zone-card");
    const dots = document.querySelectorAll(".regulator-dot");
    if (!cards.length) return;
    cards.forEach((card, i) => {
      let state = "prev";
      if (i === currentZoneIndex) state = "active";
      else if (i === (currentZoneIndex + 1) % totalZones) state = "next";
      card.setAttribute("data-state", state);
    });
    dots.forEach((dot, i) => dot.classList.toggle("active", i === currentZoneIndex));

    const scrollContainer = document.getElementById("zone-scroll-container");
    if (scrollToTarget && scrollContainer) {
      const maxScroll = scrollContainer.offsetHeight - window.innerHeight;
      const targetScroll = scrollContainer.offsetTop + (index * (maxScroll / 2));
      window.scrollTo({ top: targetScroll, behavior: "smooth" });
    }
  }

  document.querySelectorAll(".regulator-dot").forEach((dot) => {
    dot.addEventListener("click", () => {
      const idx = parseInt(dot.getAttribute("data-zone") || "0", 10);
      updateZones(idx);
    });
  });

  window.addEventListener("scroll", () => {
    const scrollContainer = document.getElementById("zone-scroll-container");
    if (!scrollContainer) return;
    const rect = scrollContainer.getBoundingClientRect();
    const scrollDistance = scrollContainer.offsetHeight - window.innerHeight;
    const currentScroll = -rect.top;
    if (currentScroll >= 0 && currentScroll <= scrollDistance) {
      let progress = currentScroll / scrollDistance;
      let newIndex = 0;
      if (progress > 0.66) newIndex = 2;
      else if (progress > 0.33) newIndex = 1;
      if (currentZoneIndex !== newIndex) updateZones(newIndex, false);
    } else if (currentScroll < 0 && currentZoneIndex !== 0) {
      updateZones(0, false);
    } else if (currentScroll > scrollDistance && currentZoneIndex !== 2) {
      updateZones(2, false);
    }
  });

  document.addEventListener("DOMContentLoaded", () => updateZones(0, false));

  // Expandable Steps
  document.querySelectorAll(".step-toggle").forEach((btn) => {
    btn.addEventListener("click", () => {
      const stepId = btn.getAttribute("data-step");
      const content = document.querySelector(`[data-content="${stepId}"]`);
      const chevron = document.querySelector(`[data-chevron="${stepId}"]`);
      const badge = document.querySelector(`[data-badge="${stepId}"]`);
      if (!content || !chevron) return;
      const expanded = content.classList.toggle("expanded");
      chevron.classList.toggle("rotate-180", expanded);
      if (badge && stepId !== "step2") {
        if (expanded) {
          badge.classList.replace("bg-zinc-800", "bg-mint");
          badge.classList.add("text-black");
        } else {
          badge.classList.replace("bg-mint", "bg-zinc-800");
          badge.classList.remove("text-black");
        }
      }
    });
  });

  // Distinction crossfade
  let isThoughts = false;
  const toggleBtn = document.getElementById("distinction-toggle");
  if (toggleBtn) {
    toggleBtn.addEventListener("click", () => {
      isThoughts = !isThoughts;
      const container = document.getElementById("distinction-container");
      const label = document.getElementById("distinction-label");
      const counter = document.getElementById("distinction-counter");
      const contentThinking = document.getElementById("content-thinking");
      const contentThoughts = document.getElementById("content-thoughts");
      const toggleLabel = document.getElementById("toggle-label");
      const toggleThumb = document.getElementById("toggle-thumb");
      const toggleBg = document.getElementById("distinction-toggle");

      if (isThoughts) {
        container.classList.replace("border-mint/20", "border-red-500/20");
        label.classList.replace("text-mint", "text-red-500");
        counter.innerText = "2 / 2";
        contentThinking.classList.replace("opacity-100", "opacity-0");
        contentThinking.classList.add("pointer-events-none");
        contentThoughts.classList.replace("opacity-0", "opacity-100");
        contentThoughts.classList.remove("pointer-events-none");
        toggleLabel.innerText = "Flip to Thinking";
        toggleBg.classList.replace("bg-zinc-800", "bg-red-500/20");
        toggleThumb.classList.replace("translate-x-0", "translate-x-7");
        toggleThumb.classList.replace("bg-mint", "bg-red-500");
      } else {
        container.classList.replace("border-red-500/20", "border-mint/20");
        label.classList.replace("text-red-500", "text-mint");
        counter.innerText = "1 / 2";
        contentThoughts.classList.replace("opacity-100", "opacity-0");
        contentThoughts.classList.add("pointer-events-none");
        contentThinking.classList.replace("opacity-0", "opacity-100");
        contentThinking.classList.remove("pointer-events-none");
        toggleLabel.innerText = "Flip to Thoughts";
        toggleBg.classList.replace("bg-red-500/20", "bg-zinc-800");
        toggleThumb.classList.replace("translate-x-7", "translate-x-0");
        toggleThumb.classList.replace("bg-red-500", "bg-mint");
      }
    });
  }

  // Compound cost reveal
  function revealCompoundCost(leader) {
    const resultA = document.getElementById("compound-result-a");
    const resultB = document.getElementById("compound-result-b");
    const btnA = document.getElementById("btn-leader-a");
    const btnB = document.getElementById("btn-leader-b");
    if (!resultA || !resultB || !btnA || !btnB) return;
    btnA.classList.remove("border-mint", "bg-mint/10");
    btnB.classList.remove("border-red-500", "bg-red-500/10");
    if (leader === "A") {
      btnA.classList.add("border-mint", "bg-mint/10");
      resultA.classList.remove("hidden");
      resultB.classList.add("hidden");
      setTimeout(() => {
        resultA.classList.remove("opacity-0", "translate-y-8");
        resultA.classList.add("opacity-100", "translate-y-0");
        resultA.scrollIntoView({ behavior: "smooth", block: "center" });
      }, 50);
    } else {
      btnB.classList.add("border-red-500", "bg-red-500/10");
      resultB.classList.remove("hidden");
      resultA.classList.add("hidden");
      setTimeout(() => {
        resultB.classList.remove("opacity-0", "translate-y-8");
        resultB.classList.add("opacity-100", "translate-y-0");
        resultB.scrollIntoView({ behavior: "smooth", block: "center" });
      }, 50);
    }
  }
  document.getElementById("btn-leader-a")?.addEventListener("click", () => revealCompoundCost("A"));
  document.getElementById("btn-leader-b")?.addEventListener("click", () => revealCompoundCost("B"));
</script>
